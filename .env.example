# Copy to .env and adjust as needed. Compose has sane defaults baked in,
# so .env is optional for local development.

# Django
# DEBUG defaults to False. For local dev, set DJANGO_DEBUG=1 — that flips on
# the dev SECRET_KEY fallback, opens CORS, and seeds ALLOWED_HOSTS for you.
DJANGO_DEBUG=1
# Required when DJANGO_DEBUG is unset/0. Leave blank in dev to use the
# (insecure) dev fallback.
DJANGO_SECRET_KEY=
# Comma-separated hostnames. Required when DEBUG is off.
DJANGO_ALLOWED_HOSTS=

# Postgres
POSTGRES_DB=qpg
POSTGRES_USER=qpg
POSTGRES_PASSWORD=qpg
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# LLM (used by bank ingestion to auto-tag questions).
# Pick one provider; only that provider's SDK needs to be installed.
# Choices: anthropic | openai | gemini. Default: anthropic.
LLM_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
