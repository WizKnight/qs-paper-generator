# Copy to .env and adjust as needed. Compose has sane defaults baked in,
# so .env is optional for local development.

# Django
# DEBUG defaults to False. For local dev, set DJANGO_DEBUG=1 — that flips on
# the dev SECRET_KEY fallback, opens CORS, and seeds ALLOWED_HOSTS for you.
DJANGO_DEBUG=1
# Required when DJANGO_DEBUG is unset/0. Leave blank in dev to use the
# (insecure) dev fallback.
DJANGO_SECRET_KEY=
# Comma-separated hostnames. Required when DEBUG is off.
DJANGO_ALLOWED_HOSTS=

# Postgres
POSTGRES_DB=qpg
POSTGRES_USER=qpg
POSTGRES_PASSWORD=qpg
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# LLM — Gemini, used by bank ingestion (native-PDF extraction, ADR-0004).
# Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
# gemini-2.5-pro for accuracy on the one-time ingest batch; switch to
# gemini-2.5-flash for cheaper re-runs.
GEMINI_MODEL=gemini-2.5-pro
LLM_TIMEOUT_SECONDS=60
