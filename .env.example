# Copy to .env and adjust as needed. Compose has sane defaults baked in,
# so .env is optional for local development.

# Django
DJANGO_SECRET_KEY=dev-insecure-key-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*

# Postgres
POSTGRES_DB=qpg
POSTGRES_USER=qpg
POSTGRES_PASSWORD=qpg
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis / Celery
REDIS_URL=redis://redis:6379/0
